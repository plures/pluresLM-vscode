{
  "name": "superlocalmemory",
  "displayName": "PluresLM — AI Memory for Copilot",
  "description": "Persistent vector memory for GitHub Copilot Chat. Remember context across sessions.",
  "version": "0.7.0",
  "publisher": "plures",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/plures/pluresLM-vscode.git"
  },
  "engines": {
    "vscode": "^1.99.0",
    "node": ">=20.19.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "memory",
    "copilot",
    "ai",
    "vector-search",
    "local-first",
    "plureslm"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "superlocalmemory.store",
        "title": "Store Memory",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.search",
        "title": "Search Memory",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.forget",
        "title": "Forget Memory",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.indexProject",
        "title": "Index Project",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.stats",
        "title": "Memory Stats",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.syncStatus",
        "title": "Sync Status",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.browseKnowledge",
        "title": "Browse Knowledge",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.viewDocumentDetails",
        "title": "View Document Details",
        "category": "Memory"
      },
      {
        "command": "superlocalmemory.deleteSource",
        "title": "Delete Source",
        "category": "Memory",
        "icon": "$(trash)"
      },
      {
        "command": "superlocalmemory.exportBundle",
        "title": "Export Memory Bundle",
        "category": "Memory",
        "icon": "$(export)"
      },
      {
        "command": "superlocalmemory.restoreBundle",
        "title": "Restore Memory Bundle",
        "category": "Memory",
        "icon": "$(history)"
      },
      {
        "command": "superlocalmemory.exportPack",
        "title": "Export Memory Pack",
        "category": "Memory",
        "icon": "$(package)"
      },
      {
        "command": "superlocalmemory.importPack",
        "title": "Import Memory Pack",
        "category": "Memory",
        "icon": "$(cloud-download)"
      },
      {
        "command": "superlocalmemory.listPacks",
        "title": "List Memory Packs",
        "category": "Memory",
        "icon": "$(list-unordered)"
      },
      {
        "command": "superlocalmemory.uninstallPack",
        "title": "Uninstall Memory Pack",
        "category": "Memory",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "PluresLM",
      "properties": {
        "superlocalmemory.mode": {
          "type": "string",
          "enum": [
            "service",
            "legacy"
          ],
          "default": "service",
          "description": "Storage mode: 'service' routes reads/writes through the plureslm-service MCP process (default); 'legacy' uses a local better-sqlite3 database."
        },
        "superlocalmemory.serviceCommand": {
          "type": "string",
          "default": "plureslm-service",
          "description": "Command used to start the plureslm-service process (service mode only). Must be on PATH or a full path."
        },
        "superlocalmemory.serviceArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments passed to the service command (service mode only)."
        },
        "superlocalmemory.serviceTimeout": {
          "type": "number",
          "default": 10000,
          "description": "Milliseconds to wait for a service response before timing out (service mode only)."
        },
        "superlocalmemory.serviceEnv": {
          "type": "object",
          "default": {},
          "description": "Extra environment variables injected into the service process (service mode only). Example: { \"PLURESLM_DB\": \"/data/memories.db\" }"
        },
        "superlocalmemory.dbPath": {
          "type": "string",
          "default": "",
          "description": "(Legacy mode) Path to memory database (default: ~/.superlocalmemory/vscode.db)"
        },
        "superlocalmemory.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "(Legacy mode) OpenAI API key to override default Transformers.js embeddings"
        },
        "superlocalmemory.openaiEmbeddingModel": {
          "type": "string",
          "default": "text-embedding-3-small",
          "description": "(Legacy mode) OpenAI embeddings model"
        },
        "superlocalmemory.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "(Legacy mode) Ollama endpoint to override default Transformers.js embeddings"
        },
        "superlocalmemory.ollamaEmbeddingModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "(Legacy mode) Ollama embedding model"
        },
        "superlocalmemory.autoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Auto-capture code patterns and decisions"
        },
        "superlocalmemory.maxRecallResults": {
          "type": "number",
          "default": 5,
          "description": "Maximum memories to recall"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "superlocalmemory",
          "title": "Memory",
          "icon": "$(brain)"
        }
      ]
    },
    "views": {
      "superlocalmemory": [
        {
          "id": "superlocalmemory.browser",
          "name": "Memories"
        },
        {
          "id": "superlocalmemory.stats",
          "name": "Stats"
        },
        {
          "id": "superlocalmemory.knowledgeBrowser",
          "name": "Knowledge Browser"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "superlocalmemory.deleteSource",
          "when": "viewItem == knowledgeSource",
          "group": "inline"
        },
        {
          "command": "superlocalmemory.viewDocumentDetails",
          "when": "viewItem == knowledgeEntry",
          "group": "inline"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "superlocalmemory.memory",
        "name": "memory",
        "fullName": "PluresLM",
        "description": "Search and store persistent memories across sessions",
        "isSticky": false,
        "commands": [
          {
            "name": "recall",
            "description": "Search memories for relevant context"
          },
          {
            "name": "store",
            "description": "Store information in long-term memory"
          },
          {
            "name": "forget",
            "description": "Remove a memory"
          },
          {
            "name": "stats",
            "description": "Show memory statistics"
          },
          {
            "name": "index",
            "description": "Index current project into memory"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "plureslm_search_text",
        "displayName": "Search Memory",
        "modelDescription": "Search the user's persistent long-term memory for relevant past context, decisions, code patterns, and error fixes. Use this to recall information from previous sessions.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "plureslm_store",
        "displayName": "Store Memory",
        "modelDescription": "Store important information in the user's persistent memory. Use for decisions, preferences, code patterns, and anything worth remembering across sessions.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "description": "Information to remember"
            },
            "category": {
              "type": "string",
              "description": "Category: decision, preference, code-pattern, error-fix, architecture"
            }
          },
          "required": [
            "content"
          ]
        }
      },
      {
        "name": "superlocalmemory_search",
        "displayName": "Search Memory (legacy)",
        "modelDescription": "Deprecated alias for plureslm_search_text. Use plureslm_search_text instead.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "superlocalmemory_store",
        "displayName": "Store Memory (legacy)",
        "modelDescription": "Deprecated alias for plureslm_store. Use plureslm_store instead.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "description": "Information to remember"
            },
            "category": {
              "type": "string",
              "description": "Category: decision, preference, code-pattern, error-fix, architecture"
            }
          },
          "required": [
            "content"
          ]
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "npx @vscode/vsce package",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "openai": "^6.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.99.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.18"
  }
}
